개선 코드
1. GicsMsgTag.java — 핵심 개선
javapublic class GicsMsgTag extends TagSupport {
    private String value;

    // ★ 핵심: MessageMappingService를 매번 getBean하지 않고 태그 인스턴스에 캐싱
    //   TagSupport는 요청 처리 중 재사용되므로 static 또는 ThreadLocal 활용
    private static volatile MessageMappingService cachedService;
    private static final Object LOCK = new Object();

    public void setValue(String value) {
        this.value = value;
    }

    private MessageMappingService getService() {
        if (cachedService == null) {
            synchronized (LOCK) {
                if (cachedService == null) {
                    cachedService = BeanUtil.getBean(MessageMappingService.class);
                }
            }
        }
        return cachedService;
    }

    @Override
    public int doStartTag() throws JspException {
        try {
            String message = getService().proceedMessage(value);
            pageContext.getOut().print(message != null ? message : value);
        } catch (Exception e) {
            // 예외 시 원본값 출력 (페이지 렌더링 중단 방지)
            try {
                pageContext.getOut().print(value);
            } catch (IOException ioe) {
                throw new JspException("gics:msg 태그 출력 오류", ioe);
            }
        }
        return SKIP_BODY;
    }
}

2. MessageMappingService.java — proceedMessage() 및 @Cacheable 개선
java@RequiredArgsConstructor
@Service
public class MessageMappingService {

    static final Logger LOGGER = LoggerFactory.getLogger(MessageMappingService.class);

    private final CommonDao commonDao;
    private final MessageService messageService;
    private final MessageCache messageCache;
    private final CacheManager cacheManager;
    // ★ applicationContext 제거 — 자기 자신 프록시 주입으로 대체
    private MessageMappingService selfProxy;

    // ★ 자기 자신을 프록시로 주입받아 @Cacheable이 정상 동작하도록 함
    @Autowired
    public void setSelfProxy(MessageMappingService selfProxy) {
        this.selfProxy = selfProxy;
    }

    /**
     * ★ 개선: @Cacheable 키에서 SessionUtil 제거
     *   - 언어코드별로 전체 맵을 캐싱하고(MessageCache.getMessagesByLang),
     *     최종 언어 분기는 proceedMessage에서 처리
     *   - SpEL에서 세션 접근 제거로 캐시 키 계산 비용 절감
     */
    public String retrieveMessageNameByValueKo(String valueKo) {
        UserSessionVO userSession = SessionUtil.getUserSession();
        String targetLanguageCode = (userSession != null) ? userSession.getLanguageCode() : "ko";
        return retrieveMessageNameByLang(valueKo, targetLanguageCode);
    }

    /**
     * ★ 신규: 언어코드를 파라미터로 받아 캐시 키를 단순하게 유지
     */
    @Cacheable(
        value = "i18nValueToCode",
        key = "#valueKo + '_' + #languageCode",
        unless = "#result == null"
    )
    public String retrieveMessageNameByLang(String valueKo, String languageCode) {
        // ko → code 역방향 조회
        Map<String, String> codeToKoMap = messageCache.getMessagesByLang("ko");
        String messageCode = codeToKoMap.entrySet().stream()
            .filter(e -> valueKo.equals(e.getValue()))
            .map(Map.Entry::getKey)
            .findFirst()
            .orElse(null);

        if (messageCode == null) return null;

        Map<String, String> targetLangMap = messageCache.getMessagesByLang(languageCode);
        return targetLangMap.getOrDefault(messageCode, valueKo);
    }

    /**
     * ★ 핵심 개선: applicationContext.getBean() 제거
     *   - selfProxy를 통해 @Cacheable 프록시 경유 보장
     */
    public String proceedMessage(String valueKo) {
        // selfProxy를 통해 @Cacheable이 적용된 메서드 호출
        String msg = selfProxy.retrieveMessageNameByLang(
            valueKo,
            getLanguageCodeSafely()
        );

        if (msg != null) {
            return msg;
        }

        return insertMessageCode(valueKo);
    }

    private String getLanguageCodeSafely() {
        try {
            UserSessionVO session = SessionUtil.getUserSession();
            return (session != null && session.getLanguageCode() != null)
                ? session.getLanguageCode() : "ko";
        } catch (Exception e) {
            return "ko";
        }
    }

    // ... 나머지 메서드는 동일 유지
}

3. MessageCache.java — 역방향 인덱스 캐싱 추가
java@RequiredArgsConstructor
@Component
@CacheConfig(cacheNames = "messages")
public class MessageCache {
    private final MessageRepository messageRepository;
    private final CommonDao commonDao;

    // ... 기존 메서드 유지 ...

    @Cacheable(key = "#languageCode")
    public Map<String, String> getMessagesByLang(String languageCode) {
        LOGGER.info("### DB에서 {} 언어 메시지 전체 로딩... ###", languageCode);
        Map<String, Object> paramMap = new HashMap<>();
        paramMap.put("languageCode", languageCode);

        List<Map<String, String>> resultList = commonDao.selectList("gics.msg.getMessagesByLang", paramMap);
        return resultList.stream()
            .collect(Collectors.toMap(
                rowMap -> rowMap.get("messageCode"),
                rowMap -> rowMap.get("messageName"),
                (oldVal, newVal) -> newVal
            ));
    }

    /**
     * ★ 신규: ko 기준 역방향 인덱스 (messageName → messageCode) 캐싱
     *   - retrieveMessageNameByValueKo의 스트림 순회 비용을 O(n) → O(1)로 감소
     */
    @Cacheable(cacheNames = "messagesInverse", key = "'ko_inverse'")
    public Map<String, String> getKoInverseIndex() {
        Map<String, String> codeToKo = getMessagesByLang("ko");
        Map<String, String> inverse = new HashMap<>(codeToKo.size());
        codeToKo.forEach((code, name) -> inverse.putIfAbsent(name, code));
        return inverse;
    }

    @Scheduled(fixedDelay = 300000, initialDelay = 300000)
    @CacheEvict(allEntries = true)
    public void refreshMessageCache() {
        LOGGER.info("### 메시지 캐시 자동 갱신 ###");
    }
}
역방향 인덱스를 사용하도록 retrieveMessageNameByLang() 수정:
java// MessageMappingService.java 내부
@Cacheable(
    value = "i18nValueToCode",
    key = "#valueKo + '_' + #languageCode",
    unless = "#result == null"
)
public String retrieveMessageNameByLang(String valueKo, String languageCode) {
    // ★ O(n) 스트림 제거 → O(1) 역방향 인덱스 조회
    Map<String, String> inverseIndex = messageCache.getKoInverseIndex();
    String messageCode = inverseIndex.get(valueKo);

    if (messageCode == null) return null;

    Map<String, String> targetLangMap = messageCache.getMessagesByLang(languageCode);
    return targetLangMap.getOrDefault(messageCode, valueKo);
}

4. CacheConfig — messagesInverse 캐시 등록 확인
java@Configuration
@EnableCaching
public class CacheConfig {
    @Bean
    public CacheManager cacheManager() {
        CaffeineCacheManager manager = new CaffeineCacheManager(
            "messages",
            "i18nValueToCode",
            "messagesInverse"   // ★ 역방향 인덱스 캐시 추가
        );
        manager.setCaffeine(Caffeine.newBuilder()
            .expireAfterWrite(10, TimeUnit.MINUTES)
            .maximumSize(10000));
        return manager;
    }
}

