logAnalysis_poweshell.ps1

# =====================================================
# 웹 침해사고 분석 스크립트 (완성본)
# =====================================================

Add-Type -AssemblyName System.IO.Compression.FileSystem

# ── 1. gz 파일 직접 읽기 함수 (스크립트 최상단에 정의) ──
function Read-GzipFile {
    param([string]$FilePath)

    $fileStream = [System.IO.File]::OpenRead($FilePath)
    $gzipStream = [System.IO.Compression.GZipStream]::new(
                      $fileStream,
                      [System.IO.Compression.CompressionMode]::Decompress)
    $reader = [System.IO.StreamReader]::new($gzipStream, [System.Text.Encoding]::UTF8)

    try {
        while (-not $reader.EndOfStream) {
            $reader.ReadLine()
        }
    }
    finally {
        $reader.Dispose()
        $gzipStream.Dispose()
        $fileStream.Dispose()
    }
}

# ── 2. 설정 ──
$logDir    = "C:\LogAnalysis\raw"
$outputDir = "C:\LogAnalysis\parsed"
New-Item -ItemType Directory -Path $outputDir -Force | Out-Null

# ── 3. 공격 패턴 정의 ──
$sqliPatterns = @(
    "union.*select", "select.*from", "or\s+1\s*=\s*1", "and\s+1\s*=\s*1",
    "'\s*--", ";\s*drop", "xp_cmdshell", "information_schema",
    "sleep\s*\(", "waitfor.*delay", "0x[0-9a-fA-F]+", "char\s*\(\d+"
)
$xssPatterns = @(
    "<script", "javascript:", "onerror\s*=", "onload\s*=",
    "onclick\s*=", "alert\s*\(", "document\.cookie", "<iframe", "<svg.*onload"
)
$webshellPatterns = @(
    "\.php\?cmd=", "\.php\?exec=", "shell\.php", "c99\.php", "r57\.php",
    "passthru", "shell_exec", "cmd=whoami", "cmd=id", "uploads.*\.php"
)

# ── 4. 결과 저장용 리스트 ──
$sqliResults     = [System.Collections.Generic.List[PSObject]]::new()
$xssResults      = [System.Collections.Generic.List[PSObject]]::new()
$webshellResults = [System.Collections.Generic.List[PSObject]]::new()

# ── 5. 로그 파일 수집 및 분석 ──
$logFiles = Get-ChildItem "$logDir\access.log.2026-*.gz" | Sort-Object Name

Write-Host "`n[+] 발견된 로그 파일: $($logFiles.Count)개" -ForegroundColor Cyan

foreach ($logFile in $logFiles) {
    Write-Host "[*] 분석 중: $($logFile.Name)" -ForegroundColor Yellow
    $lineCount = 0

    foreach ($line in (Read-GzipFile -FilePath $logFile.FullName)) {
        $lineCount++
        $lineLower = $line.ToLower()

        # SQL Injection 탐지
        foreach ($pattern in $sqliPatterns) {
            if ($lineLower -match $pattern) {
                $sqliResults.Add([PSCustomObject]@{
                    File    = $logFile.Name
                    Line    = $lineCount
                    Pattern = $pattern
                    Entry   = $line
                })
                break
            }
        }

        # XSS 탐지
        foreach ($pattern in $xssPatterns) {
            if ($lineLower -match $pattern) {
                $xssResults.Add([PSCustomObject]@{
                    File    = $logFile.Name
                    Line    = $lineCount
                    Pattern = $pattern
                    Entry   = $line
                })
                break
            }
        }

        # Web Shell 탐지
        foreach ($pattern in $webshellPatterns) {
            if ($lineLower -match $pattern) {
                $webshellResults.Add([PSCustomObject]@{
                    File    = $logFile.Name
                    Line    = $lineCount
                    Pattern = $pattern
                    Entry   = $line
                })
                break
            }
        }
    }

    Write-Host "    처리 라인: $($lineCount.ToString('N0'))건" -ForegroundColor Gray
}

# ── 6. 결과 저장 ──
$sqliResults     | Export-Csv "$outputDir\sqli.csv"     -NoTypeInformation -Encoding UTF8
$xssResults      | Export-Csv "$outputDir\xss.csv"      -NoTypeInformation -Encoding UTF8
$webshellResults | Export-Csv "$outputDir\webshell.csv" -NoTypeInformation -Encoding UTF8

# ── 7. 결과 출력 ──
Write-Host "`n========== 분석 결과 ==========" -ForegroundColor Green
Write-Host "SQL Injection 의심 : $($sqliResults.Count)건"     -ForegroundColor Red
Write-Host "XSS 의심           : $($xssResults.Count)건"      -ForegroundColor Red
Write-Host "Web Shell 의심     : $($webshellResults.Count)건"  -ForegroundColor Red
Write-Host "결과 저장 위치     : $outputDir"                   -ForegroundColor Cyan
